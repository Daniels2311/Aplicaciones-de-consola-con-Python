import json
from datetime import datetime

# simon pineda

# ESTADO GLOBAL (Variables Globales - Simulan la Base de Datos)

productos = {}       # {id_producto: {"nombre": str, "precio": float, "stock": int}}
clientes = {}        # {id_cliente: {"nombre": str, "email": str}}
pedidos = {}         # {id_pedido: {"id_cliente": int, "id_productos": list, "fecha_pedido": str}}
contador_pedidos = 1 # Autoincremental para los IDs de los pedidos


# FUNCIONES / PROCEDIMIENTOS (CRUD PRODUCTOS)

def crear_producto(id_producto, nombre, precio, stock):
    if id_producto in productos:
        print(f"[ERROR] El producto con ID {id_producto} ya existe.")
        return False
    if stock < 0:
        print("[ERROR] El stock inicial no puede ser negativo.")
        return False
    
    # Insertamos un diccionario simple en nuestro "almacén" global
    productos[id_producto] = {
        "id_producto": id_producto,
        "nombre": nombre,
        "precio": precio,
        "stock": stock
    }
    print(f"[OK] Producto '{nombre}' registrado con exito.")
    return True

def obtener_producto(id_producto):
    return productos.get(id_producto, None)

def actualizar_producto(id_producto, nombre=None, precio=None, stock=None):
    producto = obtener_producto(id_producto)
    if not producto:
        print("[ERROR] Producto no encontrado para actualizar.")
        return False
    
    if stock is not None and stock < 0:
        print("[ERROR] El stock no puede ser negativo.")
        return False
    
    if nombre is not None: producto["nombre"] = nombre
    if precio is not None: producto["precio"] = precio
    if stock is not None:  producto["stock"] = stock
    
    print(f"[ACTUALIZADO] Producto ID {id_producto} actualizado.")
    return True

def eliminar_producto(id_producto):
    if id_producto not in productos:
        print("[ERROR] El producto no existe.")
        return False
    
    # Validar si está en algún pedido (recorriendo el diccionario global)
    for pedido in pedidos.values():
        if id_producto in pedido["id_productos"]:
            print("[ERROR] No se puede eliminar el producto porque ya esta asociado a un pedido.")
            return False
            
    del productos[id_producto]
    print(f"[ELIMINADO] Producto ID {id_producto} eliminado.")
    return True

def buscar_producto_por_nombre(termino):
    return [p for p in productos.values() if termino.lower() in p["nombre"].lower()]


# FUNCIONES / PROCEDIMIENTOS (CRUD CLIENTES)

def crear_cliente(id_cliente, nombre, email):
    if id_cliente in clientes:
        print(f"[ERROR] El cliente con ID {id_cliente} ya existe.")
        return False
    
    # Validar email repetido
    for c in clientes.values():
        if c["email"].lower() == email.lower():
            print(f"[ERROR] El email '{email}' ya esta registrado.")
            return False

    clientes[id_cliente] = {
        "id_cliente": id_cliente,
        "nombre": nombre,
        "email": email
    }
    print(f"[OK] Cliente '{nombre}' registrado con exito.")
    return True

def obtener_cliente(id_cliente):
    return clientes.get(id_cliente, None)

def actualizar_cliente(id_cliente, nombre=None, email=None):
    cliente = obtener_cliente(id_cliente)
    if not cliente:
        print("[ERROR] Cliente no encontrado.")
        return False
    
    if nombre is not None: cliente["nombre"] = nombre
    if email is not None: cliente["email"] = email
    print(f"[ACTUALIZADO] Cliente ID {id_cliente} actualizado.")
    return True

def eliminar_cliente(id_cliente):
    if id_cliente not in clientes:
        print("[ERROR] El cliente no existe.")
        return False
    
    # Validar si tiene historial de pedidos
    for pedido in pedidos.values():
        if pedido["id_cliente"] == id_cliente:
            print("[ERROR] No se puede eliminar el cliente porque tiene pedidos asociados.")
            return False

    del clientes[id_cliente]
    print(f"[ELIMINADO] Cliente ID {id_cliente} eliminado.")
    return True


# FUNCIONES / PROCEDIMIENTOS (GESTIÓN DE PEDIDOS)

def crear_pedido(id_cliente, lista_id_productos):
    # Declaramos que vamos a modificar el contador global
    global contador_pedidos
    
    # 1. Validar Cliente
    if id_cliente not in clientes:
        print("[ERROR] El cliente no existe. No se puede crear el pedido.")
        return False
    
    if not lista_id_productos:
        print("[ERROR] El pedido debe contener al menos un producto.")
        return False

    # 2. Validar Existencia y Stock
    productos_a_despachar = []
    for id_prod in lista_id_productos:
        prod = obtener_producto(id_prod)
        if not prod:
            print(f"[ERROR] El producto con ID {id_prod} no existe. Pedido cancelado.")
            return False
        if prod["stock"] <= 0:
            print(f"[ERROR] El producto '{prod['nombre']}' no tiene stock disponible. Pedido cancelado.")
            return False
        productos_a_despachar.append(prod)

    # 3. Restar Stock
    for prod in productos_a_despachar:
        prod["stock"] -= 1

    # 4. Registrar Pedido
    id_pedido = contador_pedidos
    pedidos[id_pedido] = {
        "id_pedido": id_pedido,
        "id_cliente": id_cliente,
        "id_productos": lista_id_productos,
        "fecha_pedido": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    }
    contador_pedidos += 1
    
    print(f"[PEDIDO] Pedido #{id_pedido} creado con exito para el cliente ID {id_cliente}.")
    return True

def ver_historial_cliente(id_cliente):
    if id_cliente not in clientes:
        print("[ERROR] El cliente no existe.")
        return []
    
    historial = []
    for p in pedidos.values():
        if p["id_cliente"] == id_cliente:
            # Buscamos los nombres directamente en el diccionario global de productos
            nombres_productos = [productos[id_prod]["nombre"] for id_prod in p["id_productos"]]
            historial.append({
                "id_pedido": p["id_pedido"],
                "fecha": p["fecha_pedido"],
                "productos_comprados": nombres_productos
            })
    return historial

def exportar_datos_json():
    # Ya no hace falta mapear con .to_dict() porque los datos ya son diccionarios nativos
    data = {
        "clientes": list(clientes.values()),
        "productos": list(productos.values()),
        "pedidos": list(pedidos.values())
    }
    return json.dumps(data, indent=2, ensure_ascii=False)


